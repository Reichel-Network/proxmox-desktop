{
  "name": "proxtop",
  "version": "1.7.2",
  "description": "ProxTop — a full-featured desktop client for Proxmox VE",
  "author": "ProxTop",
  "license": "MIT",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c blue,green \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "npm run build:main && cross-env NODE_ENV=development electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "test": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:e2e": "npx playwright test tests/e2e/launch.spec.ts",
    "test:all": "npm run test && npm run test:integration",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production electron .",
    "dist": "npm run build && electron-builder --win --x64",
    "dist:dir": "npm run build && electron-builder --win --dir",
    "release": "npm run build && electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^3.2.6",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "com.proxtop.app",
    "productName": "ProxTop",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Reichel-Network",
        "repo": "proxmox-desktop",
        "releaseType": "release"
      }
    ]
  }
}
